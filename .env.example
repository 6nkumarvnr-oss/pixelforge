# PixelForge production environment variables
# Do not commit real secrets. Add real values in Dyad's Environment Variables panel and your Vercel project settings.

# Public browser variables for Supabase Auth
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-public-anon-key"

# Server variables used by Nitro routes
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-public-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require"
SITE_URL="https://your-production-domain.com"

# Stripe billing
STRIPE_SECRET_KEY="sk_live_or_test_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PRO_PRICE_ID="price_pro"
STRIPE_STUDIO_PRICE_ID="price_studio"

# Real image provider support
OPENAI_API_KEY="sk_openai_key_for_dalle"
SDXL_API_URL="https://your-sdxl-provider.example.com/generate"
SDXL_API_KEY="your-sdxl-provider-key"

# Optional Nitro-prefixed aliases if your host only exposes runtimeConfig via NITRO_* variables
NITRO_SUPABASE_URL="https://your-project.supabase.co"
NITRO_SUPABASE_ANON_KEY="your-public-anon-key"
NITRO_SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
NITRO_DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres?sslmode=require"
NITRO_SITE_URL="https://your-production-domain.com"
NITRO_STRIPE_SECRET_KEY="sk_live_or_test_key"
NITRO_STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
NITRO_STRIPE_PRO_PRICE_ID="price_pro"
NITRO_STRIPE_STUDIO_PRICE_ID="price_studio"
NITRO_OPENAI_API_KEY="sk_openai_key_for_dalle"
NITRO_SDXL_API_URL="https://your-sdxl-provider.example.com/generate"
NITRO_SDXL_API_KEY="your-sdxl-provider-key"
