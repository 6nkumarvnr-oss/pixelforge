generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String          @id
  email                String          @unique
  credits              Int             @default(25)
  favorites            Json            @default("[]")
  plan                 String          @default("FREE")
  subscriptionStatus   String          @default("NONE") @map("subscription_status")
  paymentStatus        String          @default("FREE") @map("payment_status")
  paymentReference     String?         @map("payment_reference")
  expiryDate           DateTime?       @map("expiry_date")
  activatedByAdmin     String?         @map("activated_by_admin")
  activatedAt          DateTime?       @map("activated_at")
  deactivatedAt        DateTime?       @map("deactivated_at")
  subscriptionNotes    String?         @map("subscription_notes")
  stripeCustomerId     String?         @unique @map("stripe_customer_id")
  stripeSubscriptionId String?         @unique @map("stripe_subscription_id")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  presets              Preset[]
  generations          Generation[]
  projects             Project[]
  brandKits            BrandKit[]
  briefs               CreativeBrief[]
  assets               Asset[]
  exportJobs           ExportJob[]
  manualPayments       ManualPaymentRecord[]

  @@map("users")
}

model Preset {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  name      String
  category  String
  tags      String[] @default([])
  prompt    String
  negative  String   @default("")
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category], map: "presets_category_idx")
  @@index([userId], map: "presets_user_id_idx")
  @@map("presets")
}

model Generation {
  id            String         @id @default(dbgenerated("gen_random_uuid()::text"))
  prompt        String
  negative      String         @default("")
  imageUrl      String         @map("image_url")
  metadata      Json           @default("{}")
  favorite      Boolean        @default(false)
  userId        String?        @map("user_id")
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String?        @map("project_id")
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  briefId       String?        @map("brief_id")
  brief         CreativeBrief? @relation(fields: [briefId], references: [id], onDelete: SetNull)
  brandKitId    String?        @map("brand_kit_id")
  brandKit      BrandKit?      @relation(fields: [brandKitId], references: [id], onDelete: SetNull)
  parentId      String?        @map("parent_id")
  parent        Generation?    @relation("GenerationVersions", fields: [parentId], references: [id], onDelete: SetNull)
  children      Generation[]   @relation("GenerationVersions")
  versionNumber Int            @default(1) @map("version_number")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  assets        Asset[]
  exportJobs    ExportJob[]

  @@index([userId, createdAt], map: "generations_user_id_created_at_idx")
  @@index([favorite], map: "generations_favorite_idx")
  @@index([projectId], map: "generations_project_id_idx")
  @@index([briefId], map: "generations_brief_id_idx")
  @@index([brandKitId], map: "generations_brand_kit_id_idx")
  @@index([parentId], map: "generations_parent_id_idx")
  @@map("generations")
}

model Project {
  id          String          @id @default(dbgenerated("gen_random_uuid()::text"))
  name        String
  description String?
  userId      String          @map("user_id")
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  generations Generation[]
  briefs      CreativeBrief[]
  assets      Asset[]
  exportJobs  ExportJob[]

  @@index([userId], map: "projects_user_id_idx")
  @@map("projects")
}

model BrandKit {
  id          String       @id @default(dbgenerated("gen_random_uuid()::text"))
  name        String
  colors      Json         @default("[]")
  fonts       Json         @default("[]")
  logoUrl     String?      @map("logo_url")
  userId      String       @map("user_id")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  generations Generation[]

  @@index([userId], map: "brand_kits_user_id_idx")
  @@map("brand_kits")
}

model CreativeBrief {
  id          String       @id @default(dbgenerated("gen_random_uuid()::text"))
  title       String
  description String?
  projectId   String?      @map("project_id")
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId      String       @map("user_id")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  generations Generation[]

  @@index([userId], map: "creative_briefs_user_id_idx")
  @@index([projectId], map: "creative_briefs_project_id_idx")
  @@map("creative_briefs")
}

model Asset {
  id           String      @id @default(dbgenerated("gen_random_uuid()::text"))
  name         String
  url          String
  type         String
  metadata     Json        @default("{}")
  projectId    String?     @map("project_id")
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  generationId String?     @map("generation_id")
  generation   Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)
  userId       String      @map("user_id")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([userId], map: "assets_user_id_idx")
  @@index([projectId], map: "assets_project_id_idx")
  @@index([generationId], map: "assets_generation_id_idx")
  @@map("assets")
}

model ManualPaymentRecord {
  id                      String    @id @default(dbgenerated("gen_random_uuid()::text"))
  userId                  String    @map("user_id")
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerEmail           String    @map("customer_email")
  customerName            String?   @map("customer_name")
  selectedPlan            String    @map("selected_plan")
  amount                  Decimal?  @db.Decimal(12, 2)
  currency                String    @default("USD")
  paymentMethod           String    @default("UPI") @map("payment_method")
  paymentReference        String?   @map("payment_reference")
  invoiceNumber           String?   @map("invoice_number")
  receiptFileUrl          String?   @map("receipt_file_url")
  receiptFileStoragePath  String?   @map("receipt_file_storage_path")
  receiptFileName         String?   @map("receipt_file_name")
  paymentStatus           String    @default("PENDING_RECEIPT") @map("payment_status")
  adminVerificationStatus String    @default("PENDING") @map("admin_verification_status")
  verifiedByAdmin         String?   @map("verified_by_admin")
  verifiedAt              DateTime? @map("verified_at")
  rejectionReason         String?   @map("rejection_reason")
  activatedPlan           String?   @map("activated_plan")
  creditsGranted          Int?      @map("credits_granted")
  validFrom               DateTime? @map("valid_from")
  validUntil              DateTime? @map("valid_until")
  notes                   String?
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  @@index([userId], map: "manual_payment_records_user_id_idx")
  @@index([paymentStatus], map: "manual_payment_records_payment_status_idx")
  @@index([adminVerificationStatus], map: "manual_payment_records_admin_verification_status_idx")
  @@index([createdAt], map: "manual_payment_records_created_at_idx")
  @@map("manual_payment_records")
}

model AdminAuditLog {
  id                 String   @id @default(dbgenerated("gen_random_uuid()::text"))
  adminUserId        String   @map("admin_user_id")
  targetUserId       String   @map("target_user_id")
  actionType         String   @map("action_type")
  previousStatus     String?  @map("previous_status")
  newStatus          String?  @map("new_status")
  previousPlan       String?  @map("previous_plan")
  newPlan            String?  @map("new_plan")
  previousExpiryDate DateTime? @map("previous_expiry_date")
  newExpiryDate      DateTime? @map("new_expiry_date")
  paymentRecordId    String?  @map("payment_record_id")
  reason             String?
  createdAt          DateTime @default(now()) @map("created_at")

  @@index([adminUserId], map: "admin_audit_logs_admin_user_id_idx")
  @@index([targetUserId], map: "admin_audit_logs_target_user_id_idx")
  @@index([paymentRecordId], map: "admin_audit_logs_payment_record_id_idx")
  @@index([createdAt], map: "admin_audit_logs_created_at_idx")
  @@map("admin_audit_logs")
}

model ExportJob {
  id           String      @id @default(dbgenerated("gen_random_uuid()::text"))
  status       String      @default("PENDING")
  format       String
  outputUrl    String?     @map("output_url")
  error        String?
  generationId String?     @map("generation_id")
  generation   Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)
  projectId    String?     @map("project_id")
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId       String      @map("user_id")
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([userId], map: "export_jobs_user_id_idx")
  @@index([generationId], map: "export_jobs_generation_id_idx")
  @@index([projectId], map: "export_jobs_project_id_idx")
  @@index([status], map: "export_jobs_status_idx")
  @@map("export_jobs")
}
